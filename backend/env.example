# ──────────────────────────────────────────────
# Belami Try-On Backend — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

PORT=3001

# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use — gemini-2.0-flash is the current recommended free model
# Other options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-preview
GEMINI_MODEL=gemini-2.0-flash

# CORS origin — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173
