{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "Install all",
      "dependsOn": ["Backend: install", "Frontend: install"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Backend: dev (port 3001)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "belami", "reveal": "always" },
      "problemMatcher": {
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*node server.js.*",
          "endsPattern": ".*Belami Try-On API ready.*"
        }
      }
    },
    {
      "label": "Frontend: dev (port 5173)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "panel": "dedicated", "group": "belami", "reveal": "always" },
      "problemMatcher": {
        "pattern": [{ "regexp": "^$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*vite.*",
          "endsPattern": ".*Local:.*http://localhost.*"
        }
      }
    },
    {
      "label": "Start Belami (both servers)",
      "dependsOn": ["Backend: dev (port 3001)", "Frontend: dev (port 5173)"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
